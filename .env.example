# Frontend (Vite) environment — copy to `.env` for local overrides.
# All are OPTIONAL. With no values set, the app runs fully on built-in mock
# data and the demo login credentials shown on the login screen.

# Set to "false" to call a real backend API instead of the mock client.
# Leave unset (or any other value) to use mock data.
VITE_USE_MOCK=true

# Base URL of the backend API, used only when VITE_USE_MOCK=false.
VITE_API_BASE_URL=https://api.awaas.example/v1
